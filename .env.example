# ===== LLM API 配置 =====
# 支持任何兼容 OpenAI 格式的 API

# MiniMax（默认推荐，新用户有免费额度）
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_API_KEY=your-minimax-api-key-here
LLM_MODEL=abab6.5-chat

# 或者使用通义千问
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=your-qwen-api-key
# LLM_MODEL=qwen-turbo

# 或者使用 DeepSeek（价格最低）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=your-deepseek-api-key
# LLM_MODEL=deepseek-chat

# 或者使用 OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-3.5-turbo

# ===== 模型参数（可调）=====
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
LLM_TOP_P=0.9

# ===== RAG 配置 =====
# 检索返回的文档数量
TOP_K=3

# Embedding 模型（本地运行，首次会自动下载）
# 推荐中文模型：paraphrase-multilingual-MiniLM-L12-v2（小巧快速）
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ===== 评测服务配置 =====
# FastAPI 评测服务端口
EVALUATION_SERVICE_PORT=8001

# LLM-as-judge 使用的模型（可以和主模型不同）
JUDGE_MODEL=abab6.5-chat
JUDGE_TEMPERATURE=0.1

# ===== 应用配置 =====
# 是否启用调试模式
DEBUG=false

# 数据目录
DATA_DIR=./data
LOG_DIR=./data/logs
